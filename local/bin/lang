#!/usr/bin/env bash

icon="/home/DrRoot/.config/dunst/icons/keyboard.svg"

# Get language
get_lang() {
	lang=$(hyprctl devices -j | gojq -r '.keyboards[] | select(.name == "at-translated-set-2-keyboard") | .active_keymap' | cut -c 1-2 | tr 'A-Z' 'a-z')
	case $lang in
		en)
			lang="English"
			;;
		ara)
			lang="العربية"
			;;
	esac
	echo $lang
}

# Notify
dunstify  -h string:x-canonical-private-synchronous:sys-notify -u low -i "$icon" "Lang : $(get_lang)"

