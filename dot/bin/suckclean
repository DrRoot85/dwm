#!/bin/sh

cd $HOME/.config/suckless/dwm && rm -f config.h 
sleep 1
doas make install clean && notify-send "DWM Done"

sleep 1

echo "##############################################################################"

cd .. && cd dmenu && rm -f config.h
sleep 1
doas make install clean && notify-send "Dmenu Done"
echo "##############################################################################"

sleep 1

cd .. && cd st && rm -f config.h
sleep 1
doas make install clean && notify-send "St Done"
echo "##############################################################################"

sleep 1

cd .. && cd slstatus && rm -f config.h
sleep 1
doas make install clean  && notify-send "Slstatus Done"
echo "##############################################################################"

sleep 1

